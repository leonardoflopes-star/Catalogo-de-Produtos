@{
    ViewData["Title"] = "Catálogo de Produtos";
    
    // Certifique-se de que estas duas linhas estão no topo para o código reconhecer as listas
    var nomes = ViewBag.ListaNomes as List<string>;
    var precos = ViewBag.ListaPrecos as List<double>;
}

<div class="container mt-4">
    <h2>Catálogo de Produtos</h2>

    <table class="table table-bordered mt-3">
        <thead>
            <tr>
                <th>#</th>
                <th>Nome do Produto</th>
                <th>Preço</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < nomes.Count; i++)
            {
                string estiloCor = "";
                
                if (precos[i] < 100.00)
                {
                    estiloCor = "color: green; font-weight: bold;";
                }

                <tr style="@estiloCor">
                    <td>@(i + 1)</td>
                    <td>@nomes[i]</td>
                    <td>R$ @precos[i].ToString("F2")</td>
                </tr>
            }
        </tbody>
    </table>

    <p class="mt-3"><strong>Total: @nomes.Count produtos</strong></p>
</div>